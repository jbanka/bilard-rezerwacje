{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allowedTools": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "TodoWrite",
      "Bash(git:*)",
      "Bash(mvn clean compile)",
      "Bash(mvn test)",
      "Bash(mvn test -pl *)",
      "Bash(mvn verify)",
      "Bash(mvn dependency:tree*)",
      "Bash(mvn versions:*)",
      "Bash(mvn spring-boot:run*)",
      "Bash(mvn package*)",
      "Bash(java -version*)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(diff *)",
      "Bash(grep *)",
      "Bash(sort *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mvn clean test)",
      "Bash(mvn clean verify)",
      "Bash(mvn clean package*)",
      "Bash(mvn help:*)",
      "Bash(mvn compile -pl *)",
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(tree *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(touch *)",
      "Bash(mv *)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/application-local.*)",
      "Read(**/application-prod*)",
      "Read(**/application-staging.*)",
      "Write(**/src/main/resources/application*.yml)",
      "Write(**/src/main/resources/application*.yaml)",
      "Write(**/src/main/resources/application*.properties)",
      "Write(**/target/**)",
      "Write(.gradle/**)",
      "Write(**/.gradle/**)",
      "Write(**/application-prod*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(mvn deploy*)",
      "Bash(git push*)",
      "Bash(git merge*)",
      "Read(**/*.jks)",
      "Read(**/*.p12)",
      "Write(**/*.jks)",
      "Write(**/*.p12)"
    ]
  }
}